# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
API_KEY=your-secret-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# File Upload
MAX_FILE_SIZE_MB=10

# AI Configuration (Groq - FREE & Recommended)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Email Configuration (Option 1: Gmail SMTP - FREE & Recommended)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an App Password for "Mail"
# 3. Copy the 16-character password
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Email Configuration (Option 2: Resend)
# RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM=Sales Automator <onboarding@resend.dev>

# Email Configuration (Option 3: Custom SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Sales Automator <noreply@example.com>
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
